#!/usr/bin/env bash

set -euo pipefail

pkg="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export PATH="$pkg/bin:${PATH:-}"
export PUB_CACHE="${PUB_CACHE:-$pkg/.pub-cache}"

code_file="$1"
shift || true

workdir=".piston-dart"
rm -rf "$workdir"
mkdir -p "$workdir/bin"

cp "$code_file" "$workdir/bin/main.dart"

cat > "$workdir/pubspec.yaml" <<'EOF'
name: piston_runtime
environment:
  sdk: ">=2.19.0 <3.0.0"
dependencies:
  collection: 1.18.0
EOF

(
  cd "$workdir"
  dart pub get --offline
  dart run bin/main.dart "$@"
)