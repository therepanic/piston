#!/usr/bin/env bash

pkg_root="${PISTON_GO_PKG_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)}"

mv "$1" "$1.go"
filename="$1.go"
shift

# Always use packaged go.mod/go.sum — submission dir may reuse a stale/partial go.sum
# left from older runs ("missing go.sum entry" otherwise).
cp "$pkg_root/go.piston.mod" go.mod
cp "$pkg_root/go.piston.sum" go.sum

GOCACHE=$PWD GOPROXY=off GOSUMDB=off go run -mod=readonly "$filename" "$@"
