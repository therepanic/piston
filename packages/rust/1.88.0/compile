#!/usr/bin/env bash
set -euo pipefail

# Fast path: link user code with pre-built dependency rlibs from package build (no cargo in isolate).
mkdir -p .piston-rust/src

mv "$1" "$1.rs"
main_file="$1.rs"
shift || true

cp "$main_file" .piston-rust/src/main.rs

if [ -z "${PISTON_RUST_PREBUILT_RELEASE:-}" ]; then
  echo "PISTON_RUST_PREBUILT_RELEASE is not set" >&2
  exit 1
fi

DEPS="${PISTON_RUST_PREBUILT_RELEASE}/deps"
if [ ! -d "$DEPS" ]; then
  echo "missing prebuilt deps: $DEPS (rebuild rust-1.88.0.pkg.tar.gz)" >&2
  exit 1
fi

pick_rlib() {
  local -a c
  shopt -s nullglob
  c=( "$DEPS"/"$1"-*.rlib )
  shopt -u nullglob
  if [ "${#c[@]}" -eq 0 ]; then
    echo "no rlib matching $1 in $DEPS" >&2
    exit 1
  fi
  echo "${c[0]}"
}

# Direct deps of the LeetCode-style stub; transitive rlibs resolve via -L.
RAND="$(pick_rlib librand)"
REGEX="$(pick_rlib libregex)"
ITERTOOLS="$(pick_rlib libitertools)"

rustc --edition 2024 -C opt-level=2 \
  -L "$DEPS" \
  --extern "rand=${RAND}" \
  --extern "regex=${REGEX}" \
  --extern "itertools=${ITERTOOLS}" \
  .piston-rust/src/main.rs -o ./binary

chmod +x ./binary
