#!/usr/bin/env bash

export RUST_INSTALL_LOC=$PWD/rust
export PATH=$RUST_INSTALL_LOC/bin:$PATH

# Keep cargo registry/checkouts inside the package, so they can be prewarmed.
export CARGO_HOME=$PWD/.cargo
export RUSTUP_HOME=$PWD/.rustup

# Vendored dependencies for offline builds
export PISTON_RUST_VENDOR=$PWD/vendor
export PISTON_RUST_LOCK=$PWD/Cargo.lock
# Full `target/release` from package-time prebuild (deps + .fingerprint + …), copied into sandbox target
export PISTON_RUST_PREBUILT_RELEASE=$PWD/rust-prebuilt-release

