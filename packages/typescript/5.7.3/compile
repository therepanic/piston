#!/usr/bin/env bash

# cwd is /box/submission; package files live next to this script (bind-mounted).
pkg="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

rename 's/$/\.ts/' "$@" # Add .ts extension

# Make deps visible: symlink into submission dir.
ln -sfn "$pkg/lib/node_modules" ./node_modules

cat > tsconfig.piston.json <<EOF
{
  "compilerOptions": {
    "alwaysStrict": true,
    "strictBindCallApply": true,
    "strictFunctionTypes": true,
    "target": "ES2024",
    "module": "commonjs",
    "moduleResolution": "node",
    "baseUrl": "$pkg/lib/node_modules",
    "typeRoots": ["$pkg/lib/node_modules/@types"]
  },
  "include": ["*.ts"]
}
EOF

tsc -p tsconfig.piston.json
