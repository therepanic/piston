#!/usr/bin/env bash

rename 's/$/\.ts/' "$@" # Add .ts extension

# Make globally installed packages visible to the compiler.
ln -sfn "$PWD/lib/node_modules" node_modules

cat > tsconfig.piston.json <<EOF
{
  "compilerOptions": {
    "alwaysStrict": true,
    "strictBindCallApply": true,
    "strictFunctionTypes": true,
    "target": "ES2024",
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@datastructures-js/*": ["$PWD/lib/node_modules/@datastructures-js/*"],
      "lodash": ["$PWD/lib/node_modules/lodash"]
    }
  },
  "include": ["*.ts"]
}
EOF

tsc -p tsconfig.piston.json

